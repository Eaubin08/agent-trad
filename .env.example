# Obsidia x ERC-8004 — Configuration
# Copier ce fichier en .env et remplir les valeurs

# Mode blockchain : "stub" (démo) ou "live" (Sepolia)
BLOCKCHAIN_MODE=stub

# Connexion Sepolia (requis pour mode live)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
AGENT_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
AGENT_WALLET=0xYOUR_WALLET_ADDRESS

# Adresses des contrats ERC-8004 sur Sepolia
# (remplacer par les adresses officielles du hackathon)
IDENTITY_REGISTRY_ADDRESS=0x...
VALIDATION_REGISTRY_ADDRESS=0x...
REPUTATION_REGISTRY_ADDRESS=0x...
RISK_ROUTER_ADDRESS=0x...

# Paramètres de trading
TRADING_SYMBOL=BTCUSDT
POSITION_SIZE_PCT=0.03
INITIAL_CAPITAL=10000.0

# Paramètres Guard X-108
GUARD_BASE_THRESHOLD=0.18
GUARD_MIN_CONSENSUS=0.55
GUARD_THETA_S=0.25
GUARD_MIN_WAIT_S=108.0
